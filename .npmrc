# better-sqlite3 v11 ships prebuilt .node binaries for Windows x64 + Node 20/22.
# This tells node-pre-gyp to download the prebuilt binary instead of compiling.
# If download fails it falls back to compiling (which needs Visual Studio).
better_sqlite3_binary_host_mirror=https://github.com/WiseLibs/better-sqlite3/releases/download/
